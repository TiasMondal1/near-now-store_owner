# Copy this file to keystore.properties (same folder) and fill in values.
# keystore.properties is gitignored — do not commit it.
#
# Create an upload keystore (one-time), e.g. put upload-keystore.jks in android/app/:
#   keytool -genkeypair -v -storetype PKCS12 -keystore upload-keystore.jks -alias upload -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile is relative to android/app/ unless you use an absolute path.
storeFile=upload-keystore.jks
storePassword=your-store-password
keyAlias=upload
keyPassword=your-key-password

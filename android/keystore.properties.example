# Copy this file to keystore.properties and fill in your values.
# keystore.properties is gitignored — never commit it.
#
# Generate a keystore with:
#   keytool -genkey -v -keystore release.keystore -alias <keyAlias> \
#           -keyalg RSA -keysize 2048 -validity 10000
#
# Place release.keystore inside android/app/ (it is also gitignored).

storeFile=release.keystore
storePassword=YOUR_STORE_PASSWORD
keyAlias=YOUR_KEY_ALIAS
keyPassword=YOUR_KEY_PASSWORD

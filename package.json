{
  "name": "shopkeeper-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export",
    "build:apk": "node scripts/build-apk-with-env.js",
    "build:aab": "node scripts/build-apk-with-env.js aab",
    "build:apk:raw": "cd android && JAVA_TOOL_OPTIONS=\"--enable-native-access=ALL-UNNAMED --add-opens=java.base/java.lang=ALL-UNNAMED --add-opens=java.base/java.io=ALL-UNNAMED\" ./gradlew assembleRelease",
    "build:apk:raw:win": "cd android && set JAVA_TOOL_OPTIONS=--enable-native-access=ALL-UNNAMED --add-opens=java.base/java.lang=ALL-UNNAMED --add-opens=java.base/java.io=ALL-UNNAMED && gradlew.bat assembleRelease",
    "build:apk:java17": "bash scripts/build-apk.sh",
    "build:android": "npx eas-cli build --platform android --profile production",
    "prebuild:android": "expo prebuild --platform android --clean"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.3.16",
    "@supabase/supabase-js": "^2.47.0",
    "expo": "^55.0.17",
    "expo-camera": "~55.0.16",
    "expo-constants": "~55.0.15",
    "expo-device": "~55.0.15",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image-picker": "~55.0.19",
    "expo-linking": "~55.0.14",
    "expo-location": "~55.1.8",
    "expo-media-library": "~55.0.15",
    "expo-notifications": "~55.0.20",
    "expo-router": "~55.0.13",
    "expo-status-bar": "~55.0.5",
    "expo-updates": "~55.0.21",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-maps": "1.27.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "glob": "^10.4.5",
    "rimraf": "^6.0.0",
    "uuid": "^14.0.0"
  },
  "private": true
}

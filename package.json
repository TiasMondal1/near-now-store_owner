{
  "name": "shopkeeper-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export",
    "build:apk": "node scripts/build-apk-with-env.js",
    "build:aab": "node scripts/build-apk-with-env.js aab",
    "build:apk:release": "node scripts/build-apk-with-env.js --alias=app_release",
    "build:apk:high-end": "node scripts/build-apk-with-env.js --arch=arm64-v8a --alias=app_high_end_arm64",
    "build:apk:low-end": "node scripts/build-apk-with-env.js --arch=armeabi-v7a --alias=app_low_end_armeabi_v7a",
    "build:apk:raw": "cd android && JAVA_TOOL_OPTIONS=\"--enable-native-access=ALL-UNNAMED --add-opens=java.base/java.lang=ALL-UNNAMED --add-opens=java.base/java.io=ALL-UNNAMED\" ./gradlew assembleRelease",
    "build:apk:raw:win": "cd android && set JAVA_TOOL_OPTIONS=--enable-native-access=ALL-UNNAMED --add-opens=java.base/java.lang=ALL-UNNAMED --add-opens=java.base/java.io=ALL-UNNAMED && gradlew.bat assembleRelease",
    "build:apk:arm64": "cd android && gradlew.bat assembleRelease -PreactNativeArchitectures=arm64-v8a",
    "build:apk:universal": "cd android && gradlew.bat assembleRelease -PreactNativeArchitectures=armeabi-v7a,arm64-v8a",
    "build:apk:java17": "bash scripts/build-apk.sh",
    "build:android": "npx eas-cli build --platform android --profile production",
    "prebuild:android": "node scripts/prebuild-android.js"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/native": "^7.1.8",
    "@react-navigation/native-stack": "^7.3.16",
    "@supabase/supabase-js": "^2.47.0",
    "expo": "~54.0.0",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.17",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "sharp": "^0.34.5",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "glob": "^10.4.5",
    "rimraf": "^6.0.0",
    "uuid": "^14.0.0"
  },
  "private": true
}
